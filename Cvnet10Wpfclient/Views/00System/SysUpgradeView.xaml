
<helpers:BaseWindow x:Class="Cvnet10Wpfclient.Views._00System.SysUpgradeView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:Cvnet10Wpfclient.Helpers"
	xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:Cvnet10Wpfclient.ViewModels._00System"
	Title="システムアップデート"
	Width="520" Height="240"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	Foreground="{DynamicResource MaterialDesignBody}"
	ResizeMode="NoResize" TextOptions.TextFormattingMode="Display"
	mc:Ignorable="d">

	<helpers:BaseWindow.DataContext>
		<vm:SysUpgradeViewModel />
	</helpers:BaseWindow.DataContext>
	<Grid>
		<StackPanel Margin="20">
			<TextBlock Margin="0,0,0,10"
				Style="{StaticResource MaterialDesignBody1TextBlock}"
				Text="ソフトウェア更新" />

			<Border Padding="15"
				BorderBrush="{StaticResource AppCommonBackgroundBrush}"
				BorderThickness="1" CornerRadius="4">
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="Auto" />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<StackPanel Grid.Column="0"
						VerticalAlignment="Center">
						<TextBlock FontWeight="Bold" Text="バージョン情報" />
						<TextBlock Margin="0,5,0,0"
							Foreground="{StaticResource plainTextColor0}"
							Text="{Binding UpdateStatus}" />
					</StackPanel>

					<Button Grid.Column="1"
						Width="120"
						Margin="10,0"
						Command="{Binding CheckUpdateCommand}"
						Content="更新を確認"
						Style="{StaticResource MaterialDesignRaisedButton}" />

					<Button Grid.Column="2"
						Width="120"
						Command="{Binding ExecuteUpdateCommand}"
						Content="今すぐ更新">
						<Button.Style>
							<Style TargetType="Button">
								<Setter Property="Visibility" Value="Visible" />
								<Style.Triggers>
									<DataTrigger Binding="{Binding IsUpdateAvailable}"
										Value="False">
										<Setter Property="Visibility" Value="Hidden" />
									</DataTrigger>
								</Style.Triggers>
							</Style>
						</Button.Style>
					</Button>
				</Grid>
				<!--
					Style="{StaticResource MaterialDesignRaisedButton}">
					Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}" />
				-->
			</Border>
			<TextBlock Margin="0,0,0,10"
				Text="{Binding OptionMessage}" />
		</StackPanel>
	</Grid>
</helpers:BaseWindow>
