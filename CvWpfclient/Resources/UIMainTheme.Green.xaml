<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<LinearGradientBrush x:Key="OuterWindowBackground"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0" Color="#40001A12" />
		<GradientStop Offset="1" Color="#15001008" />
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="CvnetMainBackgroundBrush"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0.0" Color="#FF0E4D38" />
		<GradientStop Offset="0.45" Color="#167C66" />
		<GradientStop Offset="1.0" Color="#2FA071" />
	</LinearGradientBrush>
	<SolidColorBrush x:Key="MainMenuMenuBackgroundBrush"
		Color="#2C8A67" />
	<SolidColorBrush x:Key="MainMenuDashboardCardBackgroundBrush"
		Color="#1EE8FFF5" />
	<SolidColorBrush x:Key="MainMenuDashboardCardBorderBrush"
		Color="#5537D39F" />
</ResourceDictionary>
