<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<LinearGradientBrush x:Key="OuterWindowBackground"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0" Color="#40B91C1C" />
		<GradientStop Offset="1" Color="#157F1D1D" />
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="CvnetMainBackgroundBrush"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0.0" Color="#FF7F1D1D" />
		<GradientStop Offset="0.45" Color="#DC2626" />
		<GradientStop Offset="1.0" Color="#F87171" />
	</LinearGradientBrush>
	<SolidColorBrush x:Key="MainMenuDashboardCardBackgroundBrush"
		Color="#1EFFF0F0" />
	<SolidColorBrush x:Key="MainMenuDashboardCardBorderBrush"
		Color="#55F87171" />
</ResourceDictionary>
