<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<!--
		未使用
	-->
	<LinearGradientBrush x:Key="OuterWindowBackground" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0" Color="{DynamicResource OuterWindowBackgroundStartColor}" />
		<GradientStop Offset="1" Color="{DynamicResource OuterWindowBackgroundEndColor}" />
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="CvnetMainBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0.0" Color="{DynamicResource CvnetMainBackgroundStartColor}" />
		<GradientStop Offset="0.4" Color="{DynamicResource CvnetMainBackgroundMiddleColor}" />
		<GradientStop Offset="1.0" Color="{DynamicResource CvnetMainBackgroundEndColor}" />
	</LinearGradientBrush>
	<Style x:Key="MainMenuDashboardCard"
		TargetType="Border">
		<Setter Property="Padding" Value="16" />
		<Setter Property="CornerRadius" Value="14" />
		<Setter Property="Background" Value="{DynamicResource MainMenuDashboardCardBackgroundBrush}" />
		<Setter Property="BorderBrush" Value="{DynamicResource MainMenuDashboardCardBorderBrush}" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="Margin" Value="8" />
	</Style>
	<Style x:Key="MetricLabel"
		TargetType="TextBlock">
		<Setter Property="Foreground" Value="{DynamicResource plainTextColor0}" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Opacity" Value="0.85" />
	</Style>
	<!--  Window chrome buttons  -->
	<Style x:Key="MainMenuWindowButton"
		TargetType="Button">
		<Setter Property="Width" Value="20" />
		<Setter Property="Height" Value="20" />
		<Setter Property="Margin" Value="2" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Foreground" Value="{DynamicResource TitleColor}" />
		<Setter Property="FontSize" Value="14" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border x:Name="border"
						Background="{TemplateBinding Background}"
						CornerRadius="16">
						<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="border" Property="Background" Value="{DynamicResource MainMenuWindowButtonHoverBackgroundBrush}" />
							<Setter Property="Foreground" Value="{DynamicResource MainMenuWindowButtonHoverForegroundBrush}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>

	<Style x:Key="MinimizeWinBtn"
		BasedOn="{StaticResource MainMenuWindowButton}"
		TargetType="Button">
		<Setter Property="Content" Value="-" />
		<Setter Property="Background" Value="{DynamicResource MinimizeWindowButtonBackgroundBrush}" />
	</Style>

	<Style x:Key="MaximizeWinBtn"
		BasedOn="{StaticResource MainMenuWindowButton}"
		TargetType="Button">
		<Setter Property="Content" Value="◻" />
		<Setter Property="Background" Value="{DynamicResource MenuonlyWindowButtonBackgroundBrush}" />
	</Style>
	<Style x:Key="MenuonlyWinBtn"
		BasedOn="{StaticResource MainMenuWindowButton}"
		TargetType="Button">
		<Setter Property="Content" Value="△" />
		<Setter Property="Background" Value="{DynamicResource MenuonlyWindowButtonBackgroundBrush}" />
	</Style>

	<Style x:Key="CloseWinBtn"
		BasedOn="{StaticResource MainMenuWindowButton}"
		TargetType="Button">
		<Setter Property="Content" Value="X" />
		<Setter Property="Background" Value="{DynamicResource CloseWindowButtonBackgroundBrush}" />
	</Style>

	<!--  MainMenu chips  -->
	<Style x:Key="StatusChip"
		TargetType="Border">
		<Setter Property="Padding" Value="6,4" />
		<Setter Property="CornerRadius" Value="12" />
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="{DynamicResource StatusChipBorderBrush}" />
		<Setter Property="BorderThickness" Value="1" />
	</Style>
	<Style x:Key="MenuTreeView"
		TargetType="TreeView">
		<Setter Property="Background" Value="Transparent" />
		<Setter Property="BorderBrush" Value="Transparent" />
		<Setter Property="BorderThickness" Value="0" />
		<Setter Property="Padding" Value="0" />
		<Setter Property="Margin" Value="0" />
		<Setter Property="Foreground" Value="{DynamicResource plainTextColor0}" />
	</Style>

	<Style x:Key="MenuTreeItemStyle"
		TargetType="TreeViewItem">
		<Setter Property="Foreground" Value="{DynamicResource plainTextColor0}" />
		<Setter Property="FontSize" Value="15" />
		<Setter Property="Padding" Value="6" />
		<Setter Property="Margin" Value="0,2,0,2" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="TreeViewItem">
					<StackPanel>
						<Border x:Name="border"
							Padding="4"
							Background="Transparent" CornerRadius="8">
							<ContentPresenter ContentSource="Header" />
						</Border>
						<ItemsPresenter Margin="18,0,0,0" />
					</StackPanel>
					<ControlTemplate.Triggers>
						<Trigger Property="IsSelected" Value="True">
							<Setter TargetName="border" Property="Background" Value="{DynamicResource MainMenuTreeItemSelectedBackgroundBrush}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
	<Style x:Key="SectionTitleText"
		TargetType="TextBlock">
		<Setter Property="FontSize" Value="24" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Foreground" Value="{DynamicResource TitleColor}" />
		<Setter Property="Margin" Value="0,0,0,8" />
	</Style>

	<!--  MainMenu action buttons (バージョンアップ, 環境設定, ログイン, リフレッシュトークン)  -->
	<Style x:Key="MainMenuActionButton"
		TargetType="Button">
		<Setter Property="MinWidth" Value="100" />
		<Setter Property="Height" Value="32" />
		<Setter Property="Margin" Value="4,0" />
		<Setter Property="Padding" Value="12,4" />
		<Setter Property="BorderThickness" Value="1" />
		<Setter Property="BorderBrush" Value="{DynamicResource MainMenuActionButtonBorderBrush}" />
		<Setter Property="Foreground" Value="{DynamicResource TitleColor}" />
		<Setter Property="FontSize" Value="13" />
		<Setter Property="FontWeight" Value="SemiBold" />
		<Setter Property="Cursor" Value="Hand" />
		<Setter Property="Template">
			<Setter.Value>
				<ControlTemplate TargetType="Button">
					<Border x:Name="border"
						Padding="{TemplateBinding Padding}"
						Background="{TemplateBinding Background}"
						BorderBrush="{TemplateBinding BorderBrush}"
						BorderThickness="{TemplateBinding BorderThickness}"
						CornerRadius="6">
						<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
					</Border>
					<ControlTemplate.Triggers>
						<Trigger Property="IsMouseOver" Value="True">
							<Setter TargetName="border" Property="Background" Value="{DynamicResource MainMenuActionButtonHoverBackgroundBrush}" />
						</Trigger>
						<Trigger Property="IsPressed" Value="True">
							<Setter TargetName="border" Property="Background" Value="{DynamicResource MainMenuActionButtonPressedBackgroundBrush}" />
						</Trigger>
					</ControlTemplate.Triggers>
				</ControlTemplate>
			</Setter.Value>
		</Setter>
	</Style>
</ResourceDictionary>
