<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
	<LinearGradientBrush x:Key="OuterWindowBackground"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0" Color="#40FF7A18" />
		<GradientStop Offset="1" Color="#15B54708" />
	</LinearGradientBrush>
	<LinearGradientBrush x:Key="CvnetMainBackgroundBrush"
		StartPoint="0,0" EndPoint="1,1">
		<GradientStop Offset="0.0" Color="#FF9A3412" />
		<GradientStop Offset="0.45" Color="#F97316" />
		<GradientStop Offset="1.0" Color="#FDBA74" />
	</LinearGradientBrush>
	<SolidColorBrush x:Key="MainMenuDashboardCardBackgroundBrush"
		Color="#1EFFF1E8" />
	<SolidColorBrush x:Key="MainMenuDashboardCardBorderBrush"
		Color="#55FDBA74" />
</ResourceDictionary>
