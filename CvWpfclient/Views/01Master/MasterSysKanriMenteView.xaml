<helpers:BaseWindow x:Class="CvWpfclient.Views._01Master.MasterSysKanriMenteView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:behaviors="http://schemas.microsoft.com/xaml/behaviors" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:CvWpfclient.Helpers"
	xmlns:local="clr-namespace:CvWpfclient.Views" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:vm="clr-namespace:CvWpfclient.ViewModels._01Master"
	Title="{Binding Title}"
	Width="984" Height="816"
	Background="{DynamicResource AppCommonBackgroundBrush}"
	FontSize="16"
	Foreground="{DynamicResource MaterialDesignBody}"
	TextOptions.TextFormattingMode="Display" WindowStartupLocation="CenterScreen"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:MasterSysKanriMenteViewModel />
	</helpers:BaseWindow.DataContext>
	<helpers:BaseWindow.InputBindings>
		<KeyBinding Command="{Binding DoUpdateCommand}"
			Gesture="F2" />
		<KeyBinding Command="{Binding DoDeleteCommand}"
			Gesture="F3" />
		<KeyBinding Command="{Binding DoInsertCommand}"
			Gesture="F4" />
		<KeyBinding Command="{Binding DoListCommand}"
			Gesture="F5" />
		<KeyBinding Command="{Binding DoSelKubunCommand}"
			Gesture="F6" />
	</helpers:BaseWindow.InputBindings>
	<helpers:BaseWindow.Resources>
		<Style x:Key="StatusTextBlockStyle"
			TargetType="TextBlock">
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="FontSize" Value="13" />
			<Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyLight}" />
		</Style>
		<Style x:Key="PostalSearchButton"
			BasedOn="{StaticResource MaterialDesignOutlinedButton}"
			TargetType="Button">
			<Setter Property="Margin" Value="8,0,0,0" />
			<Setter Property="Padding" Value="12,4" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="Height" Value="30" />
		</Style>
	</helpers:BaseWindow.Resources>
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button Margin="4,0"
						Command="{Binding DoUpdateCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="修正 (F2)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Pencil" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="修正" />
						</StackPanel>
					</Button>
				</StackPanel>

				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる (Esc)">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<materialDesign:PackIcon Width="28" Height="28"
						VerticalAlignment="Center"
						Kind="ApplicationSettings" />
					<TextBlock Margin="10,0,0,0" VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
					<Rectangle Width="1"
						Margin="16,4"
						Fill="{DynamicResource PrimaryHueMidForegroundBrush}"
						Opacity="0.3" />
					<Button Command="{Binding DoListCommand}"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="再読込 (F5)">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="DatabaseRefresh" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="再読込" />
						</StackPanel>
					</Button>
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<materialDesign:Card Grid.Row="1"
			Margin="12" Padding="0"
			materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<Border Grid.Row="0"
					Padding="12,8"
					Background="{DynamicResource MaterialDesignToolBarBackground}"
					CornerRadius="8,8,0,0">
					<DockPanel>
						<TextBlock DockPanel.Dock="Right"
							Style="{StaticResource StatusTextBlockStyle}"
							Text="{Binding Current.Id, StringFormat={}ID: {0:N0}}" />
						<TextBlock Style="{StaticResource StatusTextBlockStyle}"
							Text="{Binding Desc0}"
							TextTrimming="CharacterEllipsis" />
					</DockPanel>
				</Border>

				<ScrollViewer Grid.Row="1"
					Padding="8,12,20,16"
					HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
					<Grid x:Name="Shosai">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
							<RowDefinition Height="Auto" MinHeight="38" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
							<ColumnDefinition Width="Auto" MinWidth="80" />
						</Grid.ColumnDefinitions>
						<Label Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="会社名" />
						<TextBox Grid.Column="1" Grid.ColumnSpan="4"
							Height="30"
							Margin="10,0,0,0" VerticalAlignment="Center"
							d:Text="会社名"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Name}"
							TextWrapping="Wrap" />
						<Label Grid.Row="1" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="〒 住所" />
						<Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="120" />
								<ColumnDefinition Width="Auto" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>
							<TextBox Grid.Column="0"
								Height="30"
								Margin="10,0,10,0" VerticalAlignment="Center"
								d:Text="郵便番号"
								Style="{DynamicResource MaterialDesignBody*}"
								Text="{Binding Current.PostalCode, UpdateSourceTrigger=PropertyChanged}"
								TextWrapping="Wrap" />
							<Button Grid.Column="1"
								Command="{Binding SearchPostalCodeCommand}"
								Style="{StaticResource PostalSearchButton}"
								ToolTip="郵便番号から住所を検索">
								<StackPanel Orientation="Horizontal">
									<materialDesign:PackIcon Margin="0,0,6,0" VerticalAlignment="Center"
										Kind="Magnify" />
									<TextBlock VerticalAlignment="Center"
										Text="〒API検索" />
								</StackPanel>
							</Button>
						</Grid>
						<TextBox Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="4"
							Height="30"
							Margin="10,0,-17,0" VerticalAlignment="Center"
							d:Text="住所1"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Address1}"
							TextWrapping="Wrap" />
						<TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3"
							Height="30"
							Margin="10,0,10,0" VerticalAlignment="Center"
							d:Text="住所2"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Address2}"
							TextWrapping="Wrap" />
						<TextBox Grid.Row="2" Grid.Column="4" Grid.ColumnSpan="4"
							Height="30"
							Margin="10,0,-17,0" VerticalAlignment="Center"
							d:Text="住所3"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Address3}"
							TextWrapping="Wrap" />
						<Label Grid.Row="3" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="TEL   Mail" />
						<TextBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
							Height="30"
							Margin="10,0,0,0" VerticalAlignment="Center"
							d:Text="Tel"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Tel}"
							TextWrapping="Wrap" />
						<TextBox Grid.Row="3" Grid.Column="4" Grid.ColumnSpan="4"
							Height="30"
							Margin="14,0,-17,0" VerticalAlignment="Center"
							d:Text="Fax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Mail}"
							TextWrapping="Wrap" />
						<Label Grid.Row="4" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="振込先1-3" />
						<TextBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="5"
							Height="30"
							Margin="10,0,0,0" VerticalAlignment="Center"
							d:Text="Bank1"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.BankAccount1}"
							TextWrapping="Wrap" />
						<TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="5"
							Height="30"
							Margin="10,0,0,0" VerticalAlignment="Center"
							d:Text="Bank2"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.BankAccount2}"
							TextWrapping="Wrap" />
						<TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="5"
							Height="30"
							Margin="10,0,0,0" VerticalAlignment="Center"
							d:Text="Bank3"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.BankAccount3}"
							TextWrapping="Wrap" />
						<Label Grid.Row="7" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="期首年月日" />
						<DatePicker Grid.Row="7" Grid.Column="1"
							VerticalAlignment="Center"
							materialDesign:HintAssist.Hint="日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding Current.FiscalStartDate, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<Label Grid.Row="7" Grid.Column="2"
							Height="30"
							VerticalAlignment="Top"
							Content="締日" />
						<ComboBox Grid.Row="7" Grid.Column="3"
							Height="30"
							Margin="5,0,20,0"
							d:SelectedIndex="0" d:Text="締日" FontSize="14"
							ItemsSource="{Binding ShimeBiItems}"
							SelectedItem="{Binding Current.EnShimeBi, Mode=TwoWay}">
							<ComboBox.ItemTemplate>
								<DataTemplate>
									<TextBlock Foreground="{DynamicResource MaterialDesignBody}"
										Text="{Binding Converter={StaticResource EnumShimeDisplayConverter}}" />
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
						<Label Grid.Row="8" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="修正有効日数" />
						<TextBox Grid.Row="8" Grid.Column="1"
							Width="90" Height="30"
							Margin="10,0,80,0" VerticalAlignment="Center" HorizontalContentAlignment="Right"
							d:Text="修正Day"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.ModifyDaysEx}"
							TextWrapping="Wrap" />
						<Label Grid.Row="8" Grid.Column="2"
							Height="30"
							VerticalAlignment="Top"
							Content="先付有効日数" />
						<TextBox Grid.Row="8" Grid.Column="3"
							Width="90" Height="30"
							Margin="0,0,24,0" VerticalAlignment="Top" HorizontalContentAlignment="Right"
							d:Text="先付Day"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.ModifyDaysPre}"
							TextWrapping="Wrap" />
						<Label Grid.Row="10" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="税率1" />
						<TextBox Grid.Row="10" Grid.Column="1"
							Width="80" Height="30"
							Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" HorizontalContentAlignment="Right"
							d:Text="Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[0].TaxRate}"
							TextWrapping="Wrap" />
						<Label Grid.Row="10" Grid.Column="2"
							Height="30"
							VerticalAlignment="Top"
							Content="新税率切替日" />
						<DatePicker Grid.Row="10" Grid.Column="3"
							VerticalAlignment="Center"
							materialDesign:HintAssist.Hint="日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding Current.Jsub[0].DateFrom, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<Label Grid.Row="10" Grid.Column="4"
							Height="30"
							VerticalAlignment="Top"
							Content="新税率1" />
						<TextBox Grid.Row="10" Grid.Column="5"
							Width="80" Height="30"
							HorizontalAlignment="Center" VerticalAlignment="Top" HorizontalContentAlignment="Right"
							d:Text="新Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[0].TaxNewRate}" />
						<Label Grid.Row="11" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="税率2" />
						<TextBox Grid.Row="11" Grid.Column="1"
							Width="80" Height="30"
							Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" HorizontalContentAlignment="Right"
							d:Text="Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[1].TaxRate}"
							TextWrapping="Wrap" />
						<Label Grid.Row="11" Grid.Column="2"
							Height="30"
							VerticalAlignment="Top"
							Content="新税率切替日" />
						<DatePicker Grid.Row="11" Grid.Column="3"
							VerticalAlignment="Center"
							materialDesign:HintAssist.Hint="日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding Current.Jsub[1].DateFrom, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<Label Grid.Row="11" Grid.Column="4"
							VerticalAlignment="Top"
							Content="新税率2" />
						<TextBox Grid.Row="11" Grid.Column="5"
							Width="80" Height="30"
							HorizontalAlignment="Center" VerticalAlignment="Top" HorizontalContentAlignment="Right"
							d:Text="新Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[1].TaxNewRate}" />
						<Label Grid.Row="12" Grid.Column="0"
							Height="30"
							Margin="15,0,0,0" VerticalAlignment="Center"
							Content="税率3" />
						<TextBox Grid.Row="12" Grid.Column="1"
							Width="80" Height="30"
							Margin="10,0,0,0" HorizontalAlignment="Left" VerticalAlignment="Center" HorizontalContentAlignment="Right"
							d:Text="Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[2].TaxRate}"
							TextWrapping="Wrap" />
						<Label Grid.Row="12" Grid.Column="2"
							Height="30"
							VerticalAlignment="Top"
							Content="新税率切替日" />
						<DatePicker Grid.Row="12" Grid.Column="3"
							VerticalAlignment="Center"
							materialDesign:HintAssist.Hint="日付" FontSize="15" IsTodayHighlighted="False"
							SelectedDate="{Binding Current.Jsub[2].DateFrom, Converter={StaticResource DateYmd8Converter}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
							Style="{StaticResource MaterialDesignFloatingHintDatePicker}" />
						<Label Grid.Row="12" Grid.Column="4"
							Height="30"
							VerticalAlignment="Top"
							Content="新税率3" />
						<TextBox Grid.Row="12" Grid.Column="5"
							Width="80" Height="30"
							HorizontalAlignment="Center" VerticalAlignment="Top" HorizontalContentAlignment="Right"
							d:Text="新Tax"
							Style="{DynamicResource MaterialDesignBody*}"
							Text="{Binding Current.Jsub[2].TaxNewRate}" />
						<Label Grid.Row="14"
							Height="30"
							VerticalAlignment="Top"
							Content="登録日" />
						<Label Grid.Row="15"
							Height="30"
							VerticalAlignment="Top"
							Content="修正日" />
						<Label Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="2"
							Height="30"
							VerticalAlignment="Top"
							Content="{Binding Current.VdateC}" />
						<Label Grid.Row="15" Grid.Column="1"
							Height="30"
							VerticalAlignment="Top"
							Content="{Binding Current.VdateU}" />
					</Grid>
				</ScrollViewer>
			</Grid>
		</materialDesign:Card>
	</Grid>
</helpers:BaseWindow>
