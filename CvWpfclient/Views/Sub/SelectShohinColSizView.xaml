<helpers:BaseWindow x:Class="CvWpfclient.Views.Sub.SelectShohinColSizView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:helpers="clr-namespace:CvWpfclient.Helpers" xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:vm="clr-namespace:CvWpfclient.ViewModels.Sub"
	Title="{Binding Title}"
	Width="780" Height="560"
	helpers:OwnerWindowPlacement.IsEnabled="True" helpers:OwnerWindowPlacement.LeftOffset="-40" helpers:OwnerWindowPlacement.TopOffset="-20" BorderBrush="DarkSlateGray"
	BorderThickness="0.5,0,1.5,1.5" FontSize="18" WindowStartupLocation="Manual"
	mc:Ignorable="d">
	<helpers:BaseWindow.DataContext>
		<vm:SelectShohinColSizViewModel />
	</helpers:BaseWindow.DataContext>

	<Grid Background="{DynamicResource AppCommonBackgroundBrush}">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<materialDesign:ColorZone Grid.Row="0"
			Padding="12,8"
			materialDesign:ElevationAssist.Elevation="Dp4" Mode="PrimaryMid">
			<DockPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button x:Name="DefaultButton"
						Command="{Binding DoSelectCommand}"
						IsDefault="True"
						Style="{StaticResource MaterialDesignToolForegroundButton}">
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon VerticalAlignment="Center"
								Kind="Check" />
							<TextBlock Margin="6,0,0,0" VerticalAlignment="Center"
								Text="選択" />
						</StackPanel>
					</Button>
				</StackPanel>

				<StackPanel Orientation="Horizontal">
					<Button Margin="0,0,8,0"
						Command="{Binding ExitCommand}"
						IsCancel="True"
						Style="{StaticResource MaterialDesignToolForegroundButton}"
						ToolTip="閉じる">
						<materialDesign:PackIcon Kind="ArrowLeft" />
					</Button>
					<TextBlock VerticalAlignment="Center"
						FontSize="20" FontWeight="SemiBold"
						Text="{Binding Title}" />
				</StackPanel>
			</DockPanel>
		</materialDesign:ColorZone>

		<Border Grid.Row="1"
			Padding="12,6"
			Background="{DynamicResource MaterialDesignToolBarBackground}">
			<DockPanel>
				<TextBlock VerticalAlignment="Center"
					DockPanel.Dock="Right"
					Foreground="{DynamicResource MaterialDesignBodyLight}"
					Text="{Binding Count, StringFormat={}候補: {0:N0}}" />
				<StackPanel Orientation="Vertical">
					<TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}"
						Text="{Binding SearchCondition}" />
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="{Binding Current.Code_Col}" />
						<TextBlock Margin="8,0,0,0"
							Text="{Binding Current.Mei_Col}" />
						<TextBlock Margin="18,0,0,0"
							Text="{Binding Current.Code_Siz}" />
						<TextBlock Margin="8,0,0,0"
							Text="{Binding Current.Mei_Siz}" />
					</StackPanel>
				</StackPanel>
			</DockPanel>
		</Border>

		<materialDesign:Card Grid.Row="2"
			Margin="12"
			materialDesign:ElevationAssist.Elevation="Dp2" UniformCornerRadius="8">
			<DataGrid x:Name="SelectGrid"
				d:ItemsSource="{d:SampleData ItemCount=5}"
				helpers:DataGridDoubleClick.Command="{Binding DoSelectCommand}"
				helpers:DataGridEnterCommand.TargetButton="{Binding ElementName=DefaultButton}"
				helpers:DataGridSelectionBehavior.FocusOnSelectionMessage="True"
				helpers:DataGridSelectionBehavior.SelectionIdPropertyName="Id"
				materialDesign:DataGridAssist.CellPadding="12,6" materialDesign:DataGridAssist.ColumnHeaderPadding="12,8" AutoGenerateColumns="False" FrozenColumnCount="2"
				GridLinesVisibility="Horizontal"
				HorizontalGridLinesBrush="{DynamicResource MaterialDesignDivider}"
				IsReadOnly="True" IsSynchronizedWithCurrentItem="True"
				ItemsSource="{Binding ListData}"
				RowHeight="35"
				SelectedItem="{Binding Current}"
				SelectionMode="Single"
				Style="{StaticResource MaterialDesignDataGrid}"
				VerticalScrollBarVisibility="Visible">
				<DataGrid.ColumnHeaderStyle>
					<Style BasedOn="{StaticResource MaterialDesignDataGridColumnHeader}"
						TargetType="{x:Type DataGridColumnHeader}">
						<Setter Property="Background" Value="{DynamicResource PrimaryHueMidBrush}" />
						<Setter Property="Foreground" Value="{DynamicResource PrimaryHueMidForegroundBrush}" />
						<Setter Property="Padding" Value="12,8" />
						<Setter Property="FontWeight" Value="SemiBold" />
					</Style>
				</DataGrid.ColumnHeaderStyle>
				<DataGrid.Columns>
					<DataGridTextColumn Width="70"
						Binding="{Binding RowIdx}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" 行" />
					<DataGridTextColumn Width="100"
						Binding="{Binding Code_Col}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" 色CD" />
					<DataGridTextColumn Width="180"
						Binding="{Binding Mei_Col}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" 色名" />
					<DataGridTextColumn Width="110"
						Binding="{Binding Code_Siz}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" サイズCD" />
					<DataGridTextColumn Width="180"
						Binding="{Binding Mei_Siz}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" サイズ名" />
					<DataGridTextColumn Width="160"
						Binding="{Binding Jan1}"
						CanUserReorder="True" CanUserResize="True" CanUserSort="True" Header=" JAN1" />
				</DataGrid.Columns>
			</DataGrid>
		</materialDesign:Card>
	</Grid>
</helpers:BaseWindow>
